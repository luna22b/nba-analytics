// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Player {
  id              String   @id
  firstName       String
  lastName        String
  fullName        String

  height          Int?
  weight          Int?
  age             Int?
  dateOfBirth     DateTime?

  debutYear       Int?
  experienceYears Int?

  position        String?
  positionAbbr    String?

  jerseyNumber    String?

  birthCity       String?
  birthState      String?
  birthCountry    String?

  headshotUrl     String?

  active          Boolean

  teamId          String?
  team            Team? @relation(fields: [teamId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  playerStats PlayerStats[]
}
model Team {
  id              String   @id
  name            String
  displayName     String?
  abbreviation    String?

  location        String?

  logoUrl         String?

  color           String?
  alternateColor  String?

  players         Player[]
  stats           TeamStat?

  homeGames       Game[] @relation("HomeGames")
  awayGames       Game[] @relation("AwayGames")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TeamStat {
  id String @id @default(cuid())

  teamId String @unique
  team   Team @relation(fields: [teamId], references: [id])

  ppg Float?
  fgPct Float?
  threePointPct Float?

  apg Float?
  rpg Float?

  spg Float?
  bpg Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlayerStats {
  id String @id @default(cuid())

  playerId String @unique
  player Player @relation(fields: [playerId], references: [id])

  ppg Float?
  rpg Float?
  apg Float?

  fgPct Float?
  threePointPct Float?
  topg Float?
}

model Game {
  id            String   @id
  date          DateTime

  homeTeamId    String
  awayTeamId    String

  homeTeam      Team @relation("HomeGames", fields: [homeTeamId], references: [id])
  awayTeam      Team @relation("AwayGames", fields: [awayTeamId], references: [id])

  status        String  
  season        Int
  seasonType    String  

  venue         String?
  city          String?
  state         String?

  predictedWinnerId String?
  homeWinProbability Float?
  awayWinProbability Float?

  homeScore     Int?
  awayScore     Int?
  winnerId      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}